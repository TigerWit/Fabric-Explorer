{
  "extraBabelPlugins": [
    ["import", { "libraryName": "antd", "libraryDirectory": "es", "style": "css" }]
  ],
  "proxy": {
    "/api/v1/": {
      "target": "http://192.168.6.204:8080/",
      "changeOrigin": false,
      "pathRewrite": { "^/api/v1" : "" }
    },
    "/fabric": {
      "target": "http://192.168.6.204:8111/",
      "changeOrigin": false,
      "pathRewrite": { "^/fabric" : "" }
    }
  }
}
